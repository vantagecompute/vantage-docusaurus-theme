{
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2022",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.cts"],
  "exclude": [
    "node_modules",
    "lib",
    "src/theme/**/*",
    "src/css/**/*",
    "src/utils/**/*"
  ]
}
